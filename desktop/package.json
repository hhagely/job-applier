{
	"name": "job-applier-desktop",
	"version": "0.1.2",
	"private": true,
	"description": "job-applier desktop shell (Electron)",
	"homepage": "https://github.com/hhagely/job-applier",
	"author": {
		"name": "Herb Hagely",
		"email": "herb.hagely@gmail.com"
	},
	"main": "main.js",
	"scripts": {
		"start": "electron .",
		"dist": "electron-builder",
		"dev": "concurrently -k -n api,web,app -c blue,green,magenta \"npm:dev:api\" \"npm:dev:web\" \"npm:dev:app\"",
		"dev:api": "node dev-backend.mjs",
		"dev:web": "cd ../web && cross-env JOB_APPLIER_API_BASE=http://127.0.0.1:8000 npm run dev -- --host 127.0.0.1",
		"dev:app": "wait-on tcp:127.0.0.1:5174 tcp:127.0.0.1:8000 && cross-env JOB_APPLIER_DEV_URL=http://127.0.0.1:5174 JOB_APPLIER_API_BASE=http://127.0.0.1:8000 electronmon ."
	},
	"devDependencies": {
		"concurrently": "^9.1.2",
		"cross-env": "^7.0.3",
		"electron": "^33.2.0",
		"electron-builder": "^25.1.8",
		"electronmon": "^2.0.3",
		"wait-on": "^8.0.1"
	},
	"electronmon": {
		"patterns": ["main.js", "preload.js"]
	}
}
